# 复制本文件为 .env 并填入真实值
# Chat（OpenAI 兼容）：AIHubMix / 百炼 / 硅基等均可，变量名 DASHSCOPE_API_KEY 为历史兼容
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://aihubmix.com/v1
LLM_MODEL=qwen3.5-plus

# 嵌入（与 Chat 共用 base_url + key；换模型后需 reindex）
EMBEDDING_MODEL=text-embedding-v4
# 可选：AIHubMix App Store 折扣码（部分集成需要）
# AIHUBMIX_APP_CODE=

# 可选：The Guardian Open Platform（Content API，https://open-platform.theguardian.com/）
# GUARDIAN_API_KEY=your-guardian-api-key
# 可选根地址（二选一；默认 https://content.guardianapis.com）
# GUARDIAN_API_BASE=https://content.guardianapis.com
# GUARDIAN_BASE=https://content.guardianapis.com

# Optional: New York Times Article Search API
# Docs: https://developer.nytimes.com/apis
# NYT_API_KEY=your-nyt-api-key
# NYT_API_BASE=https://api.nytimes.com

# 可选：Elsevier Scopus Search API（文献库 arxiv/scopus/springer 中的 scopus）
# SCOPUS_API_KEY=your-scopus-api-key

# 可选：演示看板操作区密码（不设置则操作区默认对所有访客开放）
# DEMO_PASSWORD=your-demo-password

# 可选：五国政策源抓取（crawler/sources/policy.py）
# POLICY_EU_DAYS_BACK=14
# POLICY_BR_MAX_OFFSETS=20
# POLICY_BR_LOOKBACK_DAYS=120
# POLICY_EU_FETCH_FULL_TEXT=true
# POLICY_US_USE_API=true
# POLICY_US_API_DAYS_BACK=90
# POLICY_EU_USE_SEARCH=true
# POLICY_IN_MAX_PAGES=3

# 可选：五国政策历史回溯（scripts/backfill_policy_historical.py）
# BACKFILL_POLICY_TARGET=1000
# BACKFILL_POLICY_WINDOW_DAYS=30
# BACKFILL_POLICY_MAX_PER_WINDOW=100

# 可选：爬虫导航（crawl4ai / Playwright）
# CRAWL_PAGE_TIMEOUT_MS=90000
# CRAWL_WAIT_UNTIL=commit

# 可选：RAG 子域路由（需兼容 OpenAI 的 /embeddings；模型名依厂商填写）
# EMBEDDING_MODEL=text-embedding-v2
# RAG_TOP_K=8
# RAG_ENABLED=true
# DB_PATH=ai_governance.db
# CHROMA_PERSIST_DIR=chroma_data
